# =====================================
# BEST .gitignore for Your FYP Project
# Push almost everything important
# Ignore only unnecessary/generated files
# =====================================

# -----------------
# Python Virtual Environment
# -----------------
.venv/
venv/
ENV/
env/

# -----------------
# Python Cache Files
# -----------------
__pycache__/
*.py[cod]
*$py.class

# -----------------
# Jupyter Notebook Checkpoints
# -----------------
.ipynb_checkpoints/

# -----------------
# OS / System Files
# -----------------
.DS_Store
Thumbs.db

# -----------------
# IDE / Editor Settings
# -----------------
.vscode/
.idea/

# -----------------
# Logs / Temporary Files
# -----------------
*.log
*.tmp
*.temp

# -----------------
# Mobile App Generated Files
# -----------------
mobile_app/node_modules/
mobile_app/.expo/
mobile_app/web-build/
mobile_app/dist/

# -----------------
# Build / Distribution Files
# -----------------
build/
dist/
*.apk
*.aab

# -----------------
# Secrets / Environment Files
# -----------------
.env
.env.local
.env.*

# -----------------
# Large Raw Datasets Only
# (Keep local / share manually)
# -----------------
datasets/
data/raw/

# -----------------
# Keep ALL important files allowed:
# .json
# .csv
# .xlsx
# .pkl
# .joblib
# .h5
# models/
# source code
# requirements.txt
# package.json
# README.md
# -----------------